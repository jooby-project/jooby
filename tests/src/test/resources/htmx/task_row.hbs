<div class="task-row flex justify-between items-center p-4 hover:bg-gray-50 transition-colors group" hx-target="this" hx-swap="outerHTML">

    <input type="hidden" name="taskIds" value="{{id}}">

    <div class="text-lg font-medium text-gray-700">
        {{title}}
    </div>

    <!-- The Delete Button -->
    <!-- swap:400ms tells HTMX to wait for our CSS animation to finish before removing it from the DOM -->
    <button hx-delete="/tasks/{{id}}" hx-swap="outerHTML swap:400ms"
            class="text-red-500 hover:text-red-700 opacity-0 group-hover:opacity-100 transition-opacity p-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
    </button>
</div>